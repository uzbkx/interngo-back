PORT=3001
NODE_ENV=development

# MongoDB
# Local: mongodb://localhost:27017/interngo
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/interngo?retryWrites=true&w=majority
# Docker: mongodb://admin:password@mongo:27017/interngo?authSource=admin
MONGODB_URI=mongodb://localhost:27017/interngo

# JWT
JWT_SECRET=change-me-to-a-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-random-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Admin secret for internal/cron calls
ADMIN_SECRET=change-me-to-a-random-admin-secret

# Groq AI (scouter) — free at console.groq.com
GROQ_API_KEY=your-groq-api-key
